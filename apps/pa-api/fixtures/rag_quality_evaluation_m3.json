{
  "schema_version": "p3-m3-c3",
  "fixture_kind": "rag_quality_evaluation_rubric",
  "sensitivity": "synthetic_sanitized_no_real_records",
  "source": "golden_fixture",
  "golden_set": "retrieval_quality_golden_m3.json",
  "description": "Synthetic rubric and sample observations for PA RAG quality evaluation.",
  "metrics": [
    {
      "id": "recall_proxy",
      "area": "retrieval_quality",
      "scale": "0_to_1",
      "pass_threshold": 0.85,
      "description": "Share of expected required terms present in normalized PA Evidence for a golden case."
    },
    {
      "id": "citation_traceability",
      "area": "citation_quality",
      "scale": "0_to_1",
      "pass_threshold": 1.0,
      "description": "Whether every citation can be traced back to PA Evidence with document chunk or wiki page identifiers."
    },
    {
      "id": "source_diversity",
      "area": "retrieval_quality",
      "scale": "0_to_1",
      "pass_threshold": 0.75,
      "description": "Whether expected source types and minimum distinct titles are represented in retrieved evidence."
    },
    {
      "id": "latency",
      "area": "usability",
      "scale": "milliseconds",
      "pass_threshold": 1500,
      "description": "Observed retrieval latency for the evaluated path; live runs should record backend and end-to-end latency separately."
    },
    {
      "id": "manual_rating",
      "area": "human_review",
      "scale": "1_to_5",
      "pass_threshold": 4.0,
      "description": "Reviewer rating across retrieval fit, citation usefulness, answer grounding, task fit, material sufficiency, and reviewer confidence."
    }
  ],
  "manual_rating": {
    "scale": "1_to_5",
    "dimensions": [
      "retrieval_fit",
      "citation_usefulness",
      "answer_grounding",
      "task_fit",
      "material_sufficiency",
      "reviewer_confidence"
    ],
    "pass_threshold": 4.0
  },
  "latency": {
    "target_ms": 1500,
    "warning_ms": 2500,
    "record_required_fields": [
      "case_id",
      "backend",
      "latency_ms",
      "measured_at"
    ]
  },
