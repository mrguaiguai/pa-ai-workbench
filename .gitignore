# PA-first repository ignore policy.
# Runtime state belongs under .local/, Docker volumes, or explicitly retained
# compatibility paths. Do not broaden build/output patterns across legitimate
# source directories such as platform/weknora/cli/internal/build and output.

# OS, editor, and local agent state
.DS_Store
.idea/
.vscode/
*.swp
*.swo
.env
.env.*
!.env.example
!.env.*.example
.pa_m1_smoke_password
.agents/
.codex/

# Credentials and private material
*.pem
*.key
*.crt
*.p12
*.pfx
*_key
*_secret

# Canonical local runtime and root-scoped generated output
/.local/
/output/
/tmp/
/temp/
/logs/
*.log
*.pid

# Databases, vectors, uploads, and PA runtime state
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
/apps/pa-api/data/
/apps/pa-api/uploads/
/apps/pa-api/chroma/

# Python environments, caches, and reports
**/.venv/
**/venv/
**/__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
coverage.xml
htmlcov/
*.py[cod]

# Node package stores, caches, and generated bundles
node_modules/
/.pnpm-store/
/.npm/
/.yarn/
.vite/
*.tsbuildinfo
/dist/
/build/
/apps/pa-api/dist/
/apps/pa-api/build/
/apps/pa-web/dist/
/apps/pa-web/build/
/platform/weknora/frontend/dist/
/platform/weknora/cmd/desktop/build/bin/

# Compatibility paths retained without moving or deleting user/runtime data.
apps/pa-api/.venv
apps/pa-web/node_modules
/pa-ai-workbench/backend/.venv/
/pa-ai-workbench/backend/data/
/pa-ai-workbench/backend/uploads/
/pa-ai-workbench/frontend/node_modules/
/pa-ai-workbench/frontend/dist/
/pa-ai-workbench/logs/
/pa-ai-workbench/tmp/
/pa-ai-workbench/docs/resume_project/
