# Deny the repository by default. The PA API image receives only its three
# installable Python projects; user material, runtime data, and credentials are
# never sent in the Docker build context.
**
!.dockerignore
!apps/
!apps/pa-api/
!apps/pa-api/app/
!apps/pa-api/app/**
!apps/pa-api/pyproject.toml
!apps/pa-web/
!apps/pa-web/index.html
!apps/pa-web/package.json
!apps/pa-web/package-lock.json
!apps/pa-web/src/
!apps/pa-web/src/**
!apps/pa-web/tsconfig.json
!apps/pa-web/tsconfig.node.json
!apps/pa-web/vite.config.ts
!packages/
!packages/agent-runtime/
!packages/agent-runtime/agent/
!packages/agent-runtime/agent/**
!packages/agent-runtime/pyproject.toml
!packages/knowledge-engine/
!packages/knowledge-engine/knowledge_engine/
!packages/knowledge-engine/knowledge_engine/**
!packages/knowledge-engine/pyproject.toml
!infra/
!infra/docker/
!infra/docker/pa-web/
!infra/docker/pa-web/nginx.conf
