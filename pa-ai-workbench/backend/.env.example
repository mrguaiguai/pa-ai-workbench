# Local backend defaults for PA AI Workbench.
# Copy this file to .env for local development. Do not commit real .env files.

APP_NAME=PA AI Workbench API
APP_VERSION=0.1.0
APP_ENV=local

KNOWLEDGE_BACKEND=mock
MOCK_MODE=true

CHAT_MODEL_PROVIDER=mock
CHAT_MODEL_BASE_URL=
CHAT_MODEL_API_KEY=
CHAT_MODEL_NAME=
CHAT_MODEL_TIMEOUT_SECONDS=60
CHAT_MODEL_TEMPERATURE=0.2
MOCK_MODEL_MODE=true

EMBEDDING_PROVIDER=mock
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=
EMBEDDING_DIMENSION=1024
EMBEDDING_TIMEOUT_SECONDS=60

VECTOR_STORE_PROVIDER=mock
VECTOR_STORE_PATH=./data/chroma
VECTOR_COLLECTION_NAME=pa_workbench_chunks

DATABASE_URL=sqlite:///./data/pa_workbench.db
UPLOAD_DIR=./uploads
MEMORY_RECENT_LIMIT=10

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Optional WeKnora service account integration values.
# Leave blank unless using KNOWLEDGE_BACKEND=weknora_api for M1.
# Do not commit real tokens, workspace IDs, or knowledge-base IDs.
WEKNORA_BASE_URL=
WEKNORA_SERVICE_TOKEN=
WEKNORA_WORKSPACE_ID=
WEKNORA_DEFAULT_KB_ID=
WEKNORA_TIMEOUT_SECONDS=60
